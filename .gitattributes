# Normalize line endings and treat binaries as binary
* text=auto eol=lf

# Force LF for common text file types
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binary files (don't attempt EOL normalization or diffs)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.mov binary
*.pdf binary
*.pth binary
*.ipynb binary

# Avoid including large generated artifacts in archive exports
notebooks/checkpoints/** export-ignore
outputs/** export-ignore
checkpoints/** export-ignore
# Auto detect text files and perform LF normalization
* text=auto
